PORT=8787
OMNI_DB_PATH=./data/omni.sqlite

# AI Provider — switch from local_rules to openai for production
OMNI_AI_PROVIDER=local_rules
OMNI_AI_MODEL=guarded-draft-v1
# OMNI_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Meta Webhook
META_VERIFY_TOKEN=change-this-before-meta-webhook-setup

# Auto-reply behavior (set to 1 to enable, 0 to keep draft-only)
OMNI_META_WEBHOOK_AUTO_REPLY=0
OMNI_META_WEBHOOK_SEND=0

# Set to 1 to send ALL intents without per-intent approval (use with caution)
OMNI_AI_AUTO_SEND_ALL=0

# Page registry path (optional, defaults to server/data/pages.json)
# OMNI_PAGE_REGISTRY_PATH=./data/pages.json

# EasyStore Storefront API
EASY_STORE_SHOP=
EASY_STORE_ACCESS_TOKEN=
EASY_STORE_CLIENT_ID=
EASY_STORE_CLIENT_SECRET=

# C Snap credential vault base URL
# CSNAP_BASE_URL=http://127.0.0.1:9876

OMNI_CORS_ORIGIN=
