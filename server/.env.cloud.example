# Railway / Cloud environment variables
# Copy these into Railway dashboard -> Variables tab.

PORT=8787
# Railway production mounts the omni-server-data volume at /data.
OMNI_DB_PATH=/data/omni.sqlite

# AI Provider
OMNI_AI_PROVIDER=openai
OMNI_AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Meta Webhook
META_VERIFY_TOKEN=set-a-strong-random-string-here

# Auto-reply: draft only until tested
OMNI_META_WEBHOOK_AUTO_REPLY=1
OMNI_META_WEBHOOK_SEND=0

# Security
OMNI_ACCESS_PASSWORD=set-a-strong-password-here
OMNI_ACTION_TOKEN=set-a-strong-random-token-here
OMNI_CORS_ORIGIN=https://omni.oagent.biz

# Facebook Page Tokens
META_PAGE_TOKEN_ANNA_LYNN=
META_PAGE_TOKEN_MAN_KYND=
META_PAGE_TOKEN_PAGE_DES=
META_PAGE_TOKEN_112154661515664=

# Instagram Page Tokens
META_PAGE_TOKEN_IG_ANNA_LYNN=
META_PAGE_TOKEN_IG_MAN_KYND=
META_PAGE_TOKEN_IG_PAGE_DES=
META_PAGE_TOKEN_IG_112154661515664=

# ZORT Open API
ZORT_STORE_NAME=
ZORT_API_KEY=
ZORT_API_SECRET=

# Local helper paths. Leave empty on cloud; Omni send paths gracefully skip
# helper-only sends when the local binary is not available.
META_INBOX_HELPER=
INSTAGRAM_MESSAGING_HELPER=
ZORT_HELPER=
CSNAP_AUTH_FILE=
GEMINI_PROFILE_PATH=
